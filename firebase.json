{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "*.py",
      "template.html",
      "data.json",
      ".git/**",
      ".claude/**",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "/api/chat",
        "function": {
          "functionId": "chat",
          "region": "asia-east1"
        }
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}